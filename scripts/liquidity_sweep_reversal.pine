//@version=6
// Strategy distilled from the signal logic of "Liquidity Delta Profiler [LuxAlgo]"
// (CC BY-NC-SA 4.0, © LuxAlgo) — non-commercial, attribution, share-alike.
// This is an INDEPENDENT strategy implementation of the sweep-reversal concept,
// NOT a copy of LuxAlgo's source.  It adds real entries/exits/sizing and replaces
// the indicator's time-based win-rate display with a true backtest.
strategy("Liquidity Sweep Reversal  [LTF-delta]",
     overlay               = true,
     default_qty_type      = strategy.fixed,
     default_qty_value     = 1,
     calc_on_every_tick    = false,
     pyramiding            = 0,
     initial_capital       = 100000,
     max_labels_count      = 100)

// ═══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY SWEEP REVERSAL
//
// Thesis (from LuxAlgo's REJ/ABS reversal patterns): price sweeps a swing-high
// (buy-side liquidity) or swing-low (sell-side liquidity), grabbing stops, then
// REJECTS — closing back inside the level on volume delta OPPOSING the sweep
// (the aggressive sweepers got absorbed / trapped).  Fade the sweep.
//
// KEY UPGRADE over the indicator: real lower-timeframe intrabar delta via
// request.security_lower_tf (buy vol on up sub-bars, sell vol on down sub-bars)
// instead of the candle-direction proxy vol*(close-open)/range.
//
// ⚠️  The original indicator's top-right "win rate" is NOT a backtest (no stop,
//     a "win" = price merely ticks favorably for N bars).  This strategy uses a
//     REAL stop + target + costs.  Expect the honest numbers to be far lower.
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Inputs ───────────────────────────────────────────────────────────────────
i_pivot_len   = input.int   (15,   "Pivot length (liquidity levels)", minval=2, group="Levels")
i_sweep_buf   = input.float (0.0,  "Min sweep beyond level (%)", group="Levels",
     tooltip="How far price must poke beyond the level to count as a sweep. 0 = any breach.")
i_level_exp   = input.int   (60,   "Level expiry (bars)", group="Levels",
     tooltip="A liquidity level is tradeable for this many bars after it forms.")

i_ltf         = input.timeframe("5", "Lower timeframe for delta", group="Delta",
     tooltip="Sub-bars used to estimate intrabar buy/sell volume. Use << chart TF.")
i_delta_ratio = input.float (0.2,  "Min |delta| / volume on the sweep bar", minval=0.0, maxval=1.0, group="Delta",
     tooltip="The sweep bar's net delta must be at least this fraction of its volume, opposing the sweep.")

i_buffer_pct  = input.float (1.0,  "Stop buffer beyond sweep extreme (%)", group="Risk")
i_max_stop    = input.float (10.0, "Max allowed stop %", group="Risk")
i_rr          = input.float (2.0,  "Reward:risk target", group="Risk")
i_risk_pct    = input.float (1.5,  "Risk % of account per trade", minval=0.1, maxval=10.0, group="Risk")
i_max_pos_pct = input.float (15.0, "Max position % of equity", minval=1.0, maxval=100.0, group="Risk")
i_long        = input.bool  (true, "Allow long (SSL sweep)",  group="Direction")
i_short       = input.bool  (true, "Allow short (BSL sweep)", group="Direction")

// ═══════════════════════════════════════════════════════════════════════════════
// LOWER-TIMEFRAME INTRABAR DELTA  (real buy/sell estimate)
// ═══════════════════════════════════════════════════════════════════════════════
ltf_c = request.security_lower_tf(syminfo.tickerid, i_ltf, close)
ltf_o = request.security_lower_tf(syminfo.tickerid, i_ltf, open)
ltf_v = request.security_lower_tf(syminfo.tickerid, i_ltf, volume)

f_delta() =>
    float buy  = 0.0
    float sell = 0.0
    int n = array.size(ltf_c)
    if n > 0
        for k = 0 to n - 1
            float cc = array.get(ltf_c, k)
            float oo = array.get(ltf_o, k)
            float vv = array.get(ltf_v, k)
            if cc > oo
                buy += vv
            else if cc < oo
                sell += vv
    buy - sell

bar_delta = f_delta()
bar_vol   = volume
delta_ratio = bar_vol > 0 ? math.abs(bar_delta) / bar_vol : 0.0

// ═══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY LEVELS  (most recent confirmed swing high / low)
// ═══════════════════════════════════════════════════════════════════════════════
ph = ta.pivothigh(high, i_pivot_len, i_pivot_len)
pl = ta.pivotlow (low,  i_pivot_len, i_pivot_len)

var float bsl_level = na   // buy-side liquidity (resistance) — sweep up then fade short
var float ssl_level = na   // sell-side liquidity (support) — sweep down then fade long
var int   bsl_bar   = na
var int   ssl_bar   = na

if not na(ph)
    bsl_level := ph
    bsl_bar   := bar_index
if not na(pl)
    ssl_level := pl
    ssl_bar   := bar_index

bsl_active = not na(bsl_level) and (bar_index - bsl_bar) <= i_level_exp
ssl_active = not na(ssl_level) and (bar_index - ssl_bar) <= i_level_exp

// ═══════════════════════════════════════════════════════════════════════════════
// SWEEP + REVERSAL DETECTION
//   BSL short: high pokes above bsl_level, close back below it, delta < 0 (sellers)
//   SSL long:  low pokes below ssl_level, close back above it,  delta > 0 (buyers)
// ═══════════════════════════════════════════════════════════════════════════════
bsl_sweep = bsl_active and high > bsl_level * (1 + i_sweep_buf / 100) and close < bsl_level
ssl_sweep = ssl_active and low  < ssl_level * (1 - i_sweep_buf / 100) and close > ssl_level

short_signal = i_short and bsl_sweep and bar_delta < 0 and delta_ratio >= i_delta_ratio
long_signal  = i_long  and ssl_sweep and bar_delta > 0 and delta_ratio >= i_delta_ratio

// ═══════════════════════════════════════════════════════════════════════════════
// STOPS / TARGETS / SIZING
// ═══════════════════════════════════════════════════════════════════════════════
long_stop   = low  * (1 - i_buffer_pct / 100)
short_stop  = high * (1 + i_buffer_pct / 100)
long_risk   = close - long_stop
short_risk  = short_stop - close
long_tgt    = close + long_risk  * i_rr
short_tgt   = close - short_risk * i_rr
long_stop_ok  = long_risk  > 0 and (close - long_stop)  / close * 100 <= i_max_stop
short_stop_ok = short_risk > 0 and (short_stop - close) / close * 100 <= i_max_stop

var float cur_stop = na
var float cur_tgt  = na
var label last_label = na

flat = strategy.position_size == 0
if flat
    cur_stop := na
    cur_tgt  := na

// Long entry
if long_signal and flat and long_stop_ok
    rps = close - long_stop
    qty = math.min(math.floor(strategy.equity * i_risk_pct / 100 / rps),
                   math.floor(strategy.equity * i_max_pos_pct / 100 / close))
    if qty > 0
        strategy.entry("Long", strategy.long, qty=qty)
        cur_stop := long_stop
        cur_tgt  := long_tgt

// Short entry
if short_signal and flat and short_stop_ok
    rps = short_stop - close
    qty = math.min(math.floor(strategy.equity * i_risk_pct / 100 / rps),
                   math.floor(strategy.equity * i_max_pos_pct / 100 / close))
    if qty > 0
        strategy.entry("Short", strategy.short, qty=qty)
        cur_stop := short_stop
        cur_tgt  := short_tgt

if strategy.position_size > 0
    strategy.exit("L-exit", from_entry="Long",  stop=cur_stop, limit=cur_tgt)
if strategy.position_size < 0
    strategy.exit("S-exit", from_entry="Short", stop=cur_stop, limit=cur_tgt)

// ═══════════════════════════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════════════════════════
plot(bsl_active ? bsl_level : na, "BSL (resistance)", color=color.new(color.red, 40),  style=plot.style_linebr)
plot(ssl_active ? ssl_level : na, "SSL (support)",    color=color.new(color.green, 40), style=plot.style_linebr)
plot(strategy.position_size != 0 ? cur_stop : na, "Stop",   color=color.red,  style=plot.style_linebr, linewidth=2)
plot(strategy.position_size != 0 ? cur_tgt  : na, "Target", color=color.aqua, style=plot.style_linebr, linewidth=1)

plotshape(short_signal and flat, title="Short", style=shape.triangledown, location=location.abovebar, color=color.red,  text="S", size=size.small)
plotshape(long_signal  and flat, title="Long",  style=shape.triangleup,   location=location.belowbar, color=color.lime, text="L", size=size.small)

f_str(v) => na(v) ? "n/a" : str.tostring(math.round(v, 2))

if (long_signal or short_signal) and flat
    label.delete(last_label)
    last_label := label.new(bar_index, long_signal ? low : high,
         text  = (long_signal ? "SWEEP LONG" : "SWEEP SHORT") +
                 "\nDelta: " + f_str(bar_delta) + "  ratio: " + f_str(delta_ratio) +
                 "\nLevel: " + f_str(long_signal ? ssl_level : bsl_level),
         style = long_signal ? label.style_label_up : label.style_label_down,
         color = color.new(long_signal ? color.green : color.red, 20),
         textcolor = color.white, size = size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// PERFORMANCE ANALYTICS TABLE  (the REAL backtest — contrast w/ indicator's display)
// ═══════════════════════════════════════════════════════════════════════════════
i_show_perf = input.bool(true, "Show performance table", group="Analytics")
var table perf = table.new(position.top_left, 2, 8, border_width=1)
f_row(r, k, v, good) =>
    table.cell(perf, 0, r, k, text_color=color.white, bgcolor=color.new(color.gray, 70), text_size=size.small)
    table.cell(perf, 1, r, v, text_color=color.white, bgcolor=good ? color.new(color.green, 30) : color.new(color.gray, 50), text_size=size.small)

if i_show_perf and barstate.islast
    table.clear(perf, 0, 0, 1, 7)
    n = strategy.closedtrades
    wins = 0
    gw = 0.0
    gl = 0.0
    if n > 0
        for i = 0 to n - 1
            p = strategy.closedtrades.profit(i)
            if p > 0
                wins += 1
                gw += p
            else
                gl += math.abs(p)
    wr = n > 0 ? wins / n * 100 : 0.0
    pf = gl > 0 ? gw / gl : na
    npct = strategy.initial_capital > 0 ? strategy.netprofit / strategy.initial_capital * 100 : 0.0
    dd = strategy.initial_capital > 0 ? strategy.max_drawdown / strategy.initial_capital * 100 : 0.0
    f_row(0, "REAL BACKTEST", "(not indicator WR)", true)
    f_row(1, "Trades",        str.tostring(n), n >= 20)
    f_row(2, "Win rate",      str.tostring(math.round(wr, 1)) + "%", wr >= 45)
    f_row(3, "Profit factor", na(pf) ? "n/a" : str.tostring(math.round(pf, 2)), not na(pf) and pf >= 1.3)
    f_row(4, "Net profit %",  str.tostring(math.round(npct, 1)) + "%", npct > 0)
    f_row(5, "Max DD %",      str.tostring(math.round(dd, 1)) + "%", dd < 20)
    f_row(6, "LTF for delta", i_ltf, true)
    f_row(7, "Open trades",   str.tostring(strategy.opentrades), strategy.opentrades > 0)

// ═══════════════════════════════════════════════════════════════════════════════
// NOTES — VALIDATION REQUIRED
// • UNVERIFIED in the Python harness (LTF delta + intraday not reproducible there).
//   Backtest in TradingView (set commission + slippage in Strategy Tester).
// • request.security_lower_tf needs the chart TF > i_ltf (e.g. chart 1H, LTF 5m).
//   On a daily chart use i_ltf = "60" or "15".  Premium gives the intraday depth.
// • Compare the REAL win rate / profit factor here to the LuxAlgo indicator's
//   top-right number.  The gap is the lesson about indicator win-rate displays.
// • This is fade-the-sweep mean reversion — the same family as our backside short
//   (which had no daily edge).  The LTF-delta confirmation is the differentiator;
//   measure whether it actually adds edge.
// • Attribution: concept from Liquidity Delta Profiler [LuxAlgo], CC BY-NC-SA 4.0.
// ═══════════════════════════════════════════════════════════════════════════════
